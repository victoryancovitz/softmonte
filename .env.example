# ═══════════════════════════════════════════════════════════════════
# Softmonte — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# Nunca commite .env.local.
# ═══════════════════════════════════════════════════════════════════

# ─── Supabase (obrigatórias) ───────────────────────────────────────
# URL do projeto Supabase e chave anônima (pública, exposta no cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave service_role — USAR APENAS em rotas /api/* (server-side)
# Necessária pra criar usuários sem confirmação de email (convites)
# Dá bypass de RLS. Nunca expor no cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── IA (opcional, usado em /assistente e /api/chat) ──────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Error tracking (opcional, ativar em produção) ────────────────
# Descomente se configurar Sentry
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=sntrys_...

# ─── Rate limiting (opcional) ─────────────────────────────────────
# Usado para limitar /api/chat e /api/importar. Cria free tier no Upstash.
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXXXXxxxx

# ─── Secullum Ponto Web (integração externa) ─────────────────────
# Credenciais de um usuário Administrator habilitado em
# Maintenance → Systems Integration no Ponto Web.
# USAR APENAS server-side — nunca prefixar com NEXT_PUBLIC_.
# Docs: https://pontowebintegracaoexterna.secullum.com.br/docs/
SECULLUM_USUARIO=
SECULLUM_SENHA=

# Secret usado pelo Vercel Cron pra autorizar chamadas ao
# /api/cron/sync-ponto-diario. Gere um token aleatório longo.
CRON_SECRET=

# ─── App ──────────────────────────────────────────────────────────
# URL pública usada em emails, PWA manifest, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000
